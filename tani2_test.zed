// tani2_test.zed - keyword_tipi ve nokta sorununu bul

// --- keyword_tipi fonksiyonunun kendisini test et ---
fonk keyword_tipi_test(kelime) {
    eger kelime == "eger" { don "EGER"; }
    eger kelime == "iken" { don "IKEN"; }
    don "ID";
}

yaz "=== keyword_tipi don testi ===";
yaz keyword_tipi_test("eger");
yaz keyword_tipi_test("iken");
yaz keyword_tipi_test("xyz");

yaz "";
yaz "=== Nokta karakter testi ===";

// Nokta karakterini string icinde tara
degisken test_str = "3.14";
degisken i = 0;
degisken boy = uzunluk(test_str);
iken i < boy {
    degisken k = test_str[i];
    yaz "indeks " + i + " = '" + k + "' | nokta mi: " + (k == ".");
    i = i + 1;
}

yaz "";
yaz "=== Sadece nokta tara ===";
degisken sadece_nokta = ".";
yaz "uzunluk: " + uzunluk(sadece_nokta);
yaz "k[0]: '" + sadece_nokta[0] + "'";
yaz "k[0] == nokta: " + (sadece_nokta[0] == ".");
yaz "string == nokta: " + (sadece_nokta == ".");

yaz "";
yaz "=== Escape test ===";
// C++ lexer zaten escape cozuyor mu?
degisken esc_test = "satir\natlama";
yaz "uzunluk: " + uzunluk(esc_test);
// Eger uzunluk 13 ise \n iki karakter (ham)
// Eger uzunluk 12 ise \n tek karakter (cozulmus)
yaz "icerik: " + esc_test;
