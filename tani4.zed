degisken _s_isim  = [];
degisken _s_deger = [];

ekle(_s_isim, "x");
ekle(_s_deger, 10);

yaz _s_isim[0];
yaz _s_isim[0] == "x";

degisken aranan = "x";
yaz _s_isim[0] == aranan;

degisken i = 0;
iken i < uzunluk(_s_isim) {
    yaz "karsilastir: " + _s_isim[i] + " == x -> " + (_s_isim[i] == "x");
    eger _s_isim[i] == "x" { yaz "BULUNDU"; }
    i = i + 1;
}
