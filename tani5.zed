degisken _s_isim  = [];
degisken _s_deger = [];

ekle(_s_isim, "x");
ekle(_s_deger, 10);

fonk scope_getir(isim) {
    degisken i = uzunluk(_s_isim) - 1;
    iken i >= 0 {
        yaz "bakiyor: " + _s_isim[i] + " == " + isim;
        eger _s_isim[i] == isim {
            yaz "ESLESTI, donuyor: " + _s_deger[i];
            don _s_deger[i];
        }
        i = i - 1;
    }
    don "YOK";
}

yaz scope_getir("x");
