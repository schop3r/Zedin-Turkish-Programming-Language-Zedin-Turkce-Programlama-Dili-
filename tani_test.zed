// tani_test.zed - Zedin string indexleme davranisini anla
// Kullanim: ./zedin tani_test.zed

aktar "lexer.zed";

yaz "=== STRING INDEXLEME TANISI ===";

// Test 1: Nokta karakteri nasil geliyor?
degisken s = ".";
yaz "Nokta string uzunlugu: " + uzunluk(s);
yaz "Nokta [0] degeri: " + s[0];
yaz "Nokta == nokta: " + (s == ".");
yaz "Nokta[0] == nokta: " + (s[0] == ".");

yaz "";

// Test 2: Sayi stringi indexleme
degisken sayi_str = "3.14";
yaz "3.14 uzunlugu: " + uzunluk(sayi_str);
yaz "3.14[0] = " + sayi_str[0];
yaz "3.14[1] = " + sayi_str[1];
yaz "3.14[2] = " + sayi_str[2];
yaz "3.14[3] = " + sayi_str[3];
yaz "indeks 1 == nokta mi: " + (sayi_str[1] == ".");

yaz "";

// Test 3: Keyword tipi kontrol
degisken tip = keyword_tipi("eger");
yaz "keyword_tipi(eger) = " + tip;
degisken tip2 = keyword_tipi("degisken");
yaz "keyword_tipi(degisken) = " + tip2;

yaz "";

// Test 4: Tara ile basit test
degisken t = tara("42");
yaz "tara(42) token sayisi: " + uzunluk(t);
yaz "ilk token: " + t[0][0] + " | " + t[0][1];

yaz "";

// Test 5: Nokta iceren sayiyi tara
degisken t2 = tara("3");
yaz "tara(3) = " + t2[0][0] + " | " + t2[0][1];

// Nokta karakterini ayri tara
degisken t3 = tara(".");
yaz "tara(.) token sayisi: " + uzunluk(t3);
yaz "tara(.) ilk token tipi: " + t3[0][0];

yaz "";
yaz "=== TANI BITTI ===";
